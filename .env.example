# Copy to .env and fill in. Loaded automatically by cli.py, the local UI, and the portal.
# Real shell env vars always take precedence over these.

# LLM key — only needed for AUTOMATIC labelling (discovery + fetch work with no key).
# Use ONE of these (Anthropic recommended; web search / deep research need Anthropic).
ANTHROPIC_API_KEY=
# OPENAI_API_KEY=

# Optional: pin the model (default is claude-sonnet-4-6)
# EPISTEMIC_MODEL=claude-sonnet-4-6

# Portal URL the CLI/local-UI push & pull to
# EPISTEMIC_PORTAL=http://localhost:8810

# Contact email -> OpenAlex/Crossref "polite pool" (faster, higher limits)
# EPISTEMIC_CONTACT_EMAIL=you@example.org

# Optional: higher Semantic Scholar rate limits
# SEMANTIC_SCHOLAR_API_KEY=
